# Copy to .env and fill in values for local development.
# In production, these are stored as GitHub Actions Secrets.

# Anthropic
ANTHROPIC_API_KEY=

# Microsoft Graph (Outlook)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REFRESH_TOKEN=

# balldontlie.io free API key — required for the NBA section.
# Without it, the Bucks + NBA playoffs sub-sections degrade with a warning.
# Sign up at https://app.balldontlie.io/.
BALLDONTLIE_API_KEY=

# Optional overrides
BRIEFING_RECIPIENT=jacobgrosswi@outlook.com
BRIEFING_TZ=America/Chicago
